# ── APP ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MONGODB ──────────────────────────────────────────
# Local (direct)
MONGO_URI=mongodb://localhost:27017/boston_crm_dev
# Docker Compose (use this when running via docker compose)
# MONGO_URI=mongodb://admin:secret@mongo:27017/boston_crm_dev?authSource=admin

# ── REDIS ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Docker Compose:
# REDIS_URL=redis://redis:6379

# ── JWT ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── EMAIL (SendGrid SMTP) ─────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@bostoncrm.com
EMAIL_FROM_NAME=Boston CRM

# ── LOGGING ──────────────────────────────────────────
LOG_LEVEL=debug
